<schemadefinition xmlns="http://www.webhare.net/xmlns/wrd/schemadefinition">

  <migration tag="migrate_from_dev"
             at="create"
             stage="afterEntities"
             updatefunction="mod::devkit/lib/internal/deploy/deploysupport.whlib#MigrateForges" />

  <domain tag="forge">
    <attributes>
      <free tag="url" required="true" unique="true" />
      <free tag="token" unsafetocopy="true" />
    </attributes>
  </domain>

</schemadefinition>
