/** Wait for output analyser scans to finish
    @param folderids Ids of folders that must be completed
    @param deadline Error out when the wait hasn't completed after this time
*/
PUBLIC MACRO WaitForOutputAnalyzer(INTEGER ARRAY folderids, DATETIME deadline)
{
  OBJECT outputanalyzer := WaitForPromise(OpenWebHareService("publisher:outputanalyzer"));
  WHILE (TRUE)
  {
    RECORD state := WaitForPromise(outputanalyzer->GetState());
    INTEGER ARRAY scheduled := WaitForPromise(outputanalyzer->TestFoldersScheduled(folderids));
    //DumpValue(CELL[ state, scheduled ], "tree");
    IF (IsDefaultValue(scheduled))
      BREAK;

    Sleep(10);
    IF(GetCurrentDatetime() >= deadline)
      ABORT("outputanalyzer isn't completing");
  }
  outputanalyzer->CloseService();
}

// We need some setters implemented in HareScript to safely test troundtrips (other sources eg the test site are getting converted to TS so we're not actually testing HS code interop anymore)
PUBLIC MACRO SetSnowBeagleTabledTestDoc(INTEGER fileid) {
  OBJECT richdoctype := OpenWHFSType("http://www.webhare.net/xmlns/publisher/richdocumentfile");
  OBJECT myrichdoc := NEW RichDocument;
  myrichdoc->ImportFromRecord([ htmltext := StringToBlob('<html><head></head><body>'
                                 || '<h1 class="heading1"><a href="">Ik</a> <a name="ben">ben</a>     \neen <b>heading 1&</b></h1>'
                                 || '<p class="normal"><br/></p>'
                                 || '<p class="normal">Ik ben een <b>&lt;normale&gt;</b> <a href="http://b-lex.nl/">b-lex</a> <i>paragraaf</i><br/>met\neen      soft-break. Check deze afbeelding: <img src="cid:imagecid-81400" width="160" height="120" alt="I&#38;G" /></p>'
                                 || '<table class="maintable"><colgroup><col style="width:25px"/><caption class="wh-rtd__tablecaption">Met een captie!</caption><col style="width:45px"/></colgroup><tbody>'
                                    || '<tr>'
                                      || '<th scope="col" class="wh-rtd__tablecell"><p class="normal">Cell 1 para 1</p><p class="normal">Cell 1 para 2</p></th>'
                                       || '<th scope="col" class="cell2"><p class="normal">Cell 2 para 1</p></th>'
                                    || '</tr><tr>'
                                      || '<td class="wh-rtd__tablecell cell1" rowspan="2"><p class="normal">Cell 3</p></td>'
                                      || '<td colspan="1"><p class="normal">Cell 4</p></td>'
                                    || '</tr><tr>'
                                      || '<td><p class="normal">Next to the rowspan 2</p></td>'
                                    || '</tr>'
                                    || '</tr><tr>'
                                      || '<td colspan="2"><p class="normal">Colspan 2</p></td>'
                                    || '</tr>'
                                 || '</tbody></table>'
                                 || '</body></html>')
                 , embedded := [ MakeMergedRecord(WrapBlob(GetHarescriptResource("mod::system/web/tests/snowbeagle.jpg"),"bob.jpg"), [ contentid := "imagecid-81400" ]) ]
                 ]);;

  richdoctype->SetInstanceData(fileid, [data := myrichdoc->ExportAsRecord()]);
}

PUBLIC MACRO SetSnowBeagleWidgetTestDoc(INTEGER fileid) {
  RECORD testimage := WrapBlob(GetWebHareResource("mod::system/web/tests/goudvis.png"),"goudvis.png");
  OBJECT widget1 := OpenWHFSObjectByPath("site::webhare_testsuite.testsitejs/testpages/htmlwidget", [expect := "file"]);
  OBJECT widget2 := OpenWHFSObjectByPath("site::webhare_testsuite.testsitejs/testpages/jswidget", [expect := "file"]);
  OBJECT imgeditfile := OpenWHFSObjectByPath("site::webhare_testsuite.testsitejs/testpages/imgeditfile.jpeg", [expect := "file"]);
  OBJECT rangetestfile := OpenWHFSObjectByPath("site::webhare_testsuite.testsitejs/testpages/rangetestfile.jpeg", [expect := "file"]);
  OpenWHFSObject(fileid)->SetInstanceData("http://www.webhare.net/xmlns/publisher/richdocumentfile",
          [ data := [ htmltext := StringToBlob(
                                                    `<html><body>
                                                      <p class="normal">indirect html widget:</p>
                                                      <div class="wh-rtd-embeddedobject" data-instanceid="holder1"></div>
                                                      <p class="normal">indirect jswidget:</p>
                                                      <div class="wh-rtd-embeddedobject" data-instanceid="holder2"></div>
                                                      <p class="normal">Een afbeelding: <img src="cid:imagecid-81400" width="160" height="120" alt="I&amp;G" /></p>
                                                      <p class="normal">Een <a href="https://beta.webhare.net/">externe</a> en een <a href="x-richdoclink:1234-5678-001#dieper">interne</a> link.</p>
                                                    </body></html>`)
                    , instances := [ [ instanceid := "holder1"
                                    , data := [ whfstype := "http://www.webhare.net/xmlns/webhare_testsuite/rtd/widgetblock"
                                              , widgets := INTEGER[widget1->id]
                                              ]
                                    ]
                                  , [ instanceid := "holder2"
                                    , data := [ whfstype := "http://www.webhare.net/xmlns/webhare_testsuite/rtd/widgetblock"
                                              , widgets := INTEGER[widget2->id]
                                              ]
                                    ]
                                  ]
                    , embedded := [ CELL[...WrapBlob(GetHarescriptResource("mod::system/web/tests/snowbeagle.jpg"), "bob.jpg", [ extractdominantcolor := TRUE ])
                                        , contentid := "imagecid-81400"
                                        , source_fsobject := imgeditfile->Id
                                    ]
                                  ]
                    , links := [[ tag := "1234-5678-001", linkref := rangetestfile->id ]]
                  ]
          ]);

}

VARIANT FUNCTION Ternary(BOOLEAN test, VARIANT iftrue, VARIANT iffalse) {
  IF(test)
    RETURN iftrue;
  RETURN iffalse;
}

PUBLIC MACRO VerifyTSHistory(INTEGER fileid) {
  RECORD ARRAY hs_history;
  FOREVERY(RECORD entry FROM ListObjectHistory(fileid, [ include_autosaves := TRUE ])) {
    INSERT CELL[ entry.id
               , entry.name
               , entry.type
               , user_auth_object := Ternary(entry.user != 0, entry.user, DEFAULT RECORD)
               , user_data := entry.userdata
               , entry.when
               , snapshot := Ternary(entry.snapshot != 0, entry.snapshot, DEFAULT RECORD)
               , entry.version
               , is_active := entry.isactive
               //FIXME userdata
               ] INTO hs_history AT END;
  }

  RECORD ARRAY ts_history := CallJS([ camelcase := TRUE ], "mod::webhare_testsuite/js/whfs.ts#listObjHistory", fileid);
  TestEq(hs_history, ts_history);
}
