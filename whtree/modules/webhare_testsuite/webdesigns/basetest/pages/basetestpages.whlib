<?wh

LOADLIB "wh::xml/xsd.whlib";

LOADLIB "mod::publisher/lib/webdesign.whlib";

LOADLIB "mod::system/lib/webserver.whlib";

PUBLIC OBJECTTYPE WebStaticPage EXTEND StaticPageBase
<
  UPDATE PUBLIC MACRO RunBody(OBJECT webdesign)
  {
    Print('<div id="webstaticpage">WebStaticPage</div>');
  }
>;

PUBLIC OBJECTTYPE DynamicPage EXTEND WebPageBase
<
  UPDATE PUBLIC MACRO PTR FUNCTION GetPageBody()
  {
    OBJECT gtmplugin := this->webdesign->GetPlugin("http://www.webhare.net/xmlns/publisher/siteprofile","gtm");
    IF(ObjectExists(gtmplugin))
    {
      IF(GetWebVariable("gtmplugin_integration") = "none")
      {
        gtmplugin->account := "";
      }
      ELSE
      {
        gtmplugin->DatalayerPush([ val := "HiThere", filename := this->webdesign->targetobject->name ]);
        gtmplugin->integration := GetWebVariable("gtmplugin_integration") ?? gtmplugin->integration;
        gtmplugin->launch := GetWebVariable("gtmplugin_launch") ?? gtmplugin->launch;
      }
    }

    OBJECT ga4plugin := this->webdesign->GetPlugin("http://www.webhare.net/xmlns/publisher/siteprofile","googleanalytics4");
    IF(ObjectExists(ga4plugin))
    {
      IF(GetWebVariable("ga4_integration") = "none")
      {
        ga4plugin->account := "";
      }
      ELSE
      {
        IF(GetWebVariable("ga4_integration") != "")
          ga4plugin->integration := GetWebVariable("ga4_integration");

        IF(GetWebVariable("ga4_anonymizeip") != "")
          ga4plugin->anonymizeip := ParseXSBoolean(GetWebVariable("ga4_anonymizeip"));
      }
    }

    IF(GetWebVariable("shareimage") = "1") {
      this->webdesign->ogshareimage := this->webdesign->targetsite->webroot || "TestPages/rangetestfile.jpeg";
    }
    IF(GetWebVariable("sharedescription") = "1") {
      this->webdesign->ogsharetitle := "A share title";
      this->webdesign->ogsharedescription := "A share description";
    }

    RETURN PTR Print(`<div id="dynamicpage"></div>`);
  }
>;

PUBLIC OBJECTTYPE DynamicPageOverride EXTEND WebPageBase <
  UPDATE PUBLIC MACRO PTR FUNCTION GetPageBody() {
    this->webdesign->SetPageBuilderData("webhare_testsuite:dynamicpageinfo", CELL[ echo_web_var := GetWebVariable("echo") ]);
    this->webdesign->SetFrontendData("webhare_testsuite:dynamicpagefrontend", CELL[ echo_web_var := GetWebVariable("echo") ]);
    RETURN PTR Print(`<div id="dynamicpage_override">This is DynamicPageOverride with echo=${EncodeHTML(GetWebVariable("echo"))}</div>`);
  }
>;
