{
	"name": "webhare-language-vscode",
	"displayName": "WebHare language client",
	"description": "WebHare language client for Visual Studio Code",
	"author": "WebHare bv",
	"publisher": "webhare",
	"icon": "images/webhare.png",
	"license": "MIT",
	"version": "1.0.1",
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/webhare/platform"
	},
	"engines": {
		"vscode": "^1.108.1"
	},
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:xml",
		"onLanguage:yaml",
		"onLanguage:webhare-screens-xml",
		"onLanguage:webhare-siteprofile-xml"
	],
	"main": "./dist/extension",
	"contributes": {
		"languages": [
			{
				"id": "harescript",
				"extensions": [
					".whlib",
					".whscr",
					".whsock",
					".shtml"
				],
				"firstLine": "^<\\?wh",
				"aliases": [
					"HareScript"
				],
				"configuration": "./filetypes/harescript/harescript.language-configuration.json"
			},
			{
				"id": "witty-template",
				"extensions": [
					".witty"
				],
				"firstLine": "[component",
				"aliases": [
					"Witty Template"
				],
				"configuration": "./filetypes/witty/witty.language-configuration.json"
			},
			{
				"id": "javascriptreact",
				"extensions": [
					".es"
				]
			},
			{
				"id": "webhare-screens-xml",
				"extensions": [
					".screens.xml"
				],
				"firstLine": "<screens",
				"aliases": [
					"WebHare Screens XML"
				]
			},
			{
				"id": "webhare-siteprofile-xml",
				"extensions": [
					".siteprl.xml"
				],
				"firstLine": "<siteprofle",
				"aliases": [
					"WebHare Siteprofile XML"
				]
			}
		],
		"grammars": [
			{
				"language": "harescript",
				"scopeName": "source.harescript",
				"path": "./filetypes/harescript/harescript.tmGrammar.json"
			},
			{
				"language": "webhare-screens-xml",
				"scopeName": "source.webharescreensxml",
				"path": "./filetypes/screens-xml/screensxml.tmGrammar.json"
			},
			{
				"language": "webhare-siteprofile-xml",
				"scopeName": "source.webharesiteprofilexml",
				"path": "./filetypes/siteprofiles-xml/siteprofiles.tmGrammar.json"
			},
			{
				"language": "witty-template",
				"scopeName": "source.witty-template",
				"path": "./filetypes/witty/witty.tmGrammar.json"
			}
		],
		"snippets": [
			{
				"language": "harescript",
				"path": "./filetypes/harescript/harescript.json.code-snippets"
			},
			{
				"language": "webhare-screens-xml",
				"path": "./filetypes/screens-xml/screensxml.json.code-snippets"
			},
			{
				"language": "webhare-screens-xml",
				"path": "./filetypes/screens-xml/screensxml-shared.json.code-snippets"
			},
			{
				"language": "webhare-siteprofile-xml",
				"path": "./filetypes/siteprofiles-xml/siteprofiles.json.code-snippets"
			},
			{
				"language": "webhare-siteprofile-xml",
				"path": "./filetypes/screens-xml/screensxml-shared.json.code-snippets"
			},
			{
				"language": "typescript",
				"path": "./filetypes/typescript/typescript.json.code-snippets"
			},
			{
				"language": "witty-template",
				"path": "./filetypes/witty/witty.json.code-snippets"
			}
		],
		"xmlLanguageParticipants": [
			{
				"languageId": "webhare-screens-xml"
			},
			{
				"languageId": "webhare-siteprofile-xml"
			}
		],
		"commands": [
			{
				"command": "webhare.getStackTrace",
				"title": "WebHare: Get Stack Trace"
			},
			{
				"command": "webhare.showStackTrace",
				"title": "WebHare: Show Last Stack Trace"
			},
			{
				"command": "webhare.getLastStackTraces",
				"title": "WebHare: Get Last Stack Traces"
			},
			{
				"command": "webhare.copyResourcePath",
				"title": "WebHare: Copy WebHare Resource path"
			},
			{
				"command": "webhare.run",
				"title": "WebHare: Run this script"
			}
		],
		"keybindings": [
			{
				"command": "webhare.run",
				"key": "shift+alt+r"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "webhare.getStackTrace"
				},
				{
					"command": "webhare.showStackTrace"
				},
				{
					"command": "webhare.getLastStackTraces"
				},
				{
					"command": "webhare.run",
					"when": "resourceLangId == harescript || resourceLangId == typescript"
				}
			],
			"editor/title/context": [
				{
					"command": "webhare.copyResourcePath",
					"group": "navigation"
				},
				{
					"command": "webhare.run",
					"group": "navigation",
					"when": "resourceLangId == harescript || resourceLangId == typescript"
				}
			],
			"explorer/context": [
				{
					"command": "webhare.copyResourcePath",
					"group": "navigation"
				},
				{
					"command": "webhare.run",
					"group": "navigation",
					"when": "resourceLangId == harescript || resourceLangId == typescript"
				}
			]
		},
		"configuration": {
			"title": "WebHare",
			"properties": {
				"webhare.debugLoglevel": {
					"type": "integer",
					"default": 0,
					"description": "The amount of information to log to the debug log",
					"enum": [
						0,
						1,
						2,
						3
					],
					"enumDescriptions": [
						"Log only errors",
						"Log information about document state",
						"Log all requests and responses",
						"Log all debugging information"
					]
				},
				"webhare.runkitpath": {
					"type": "string",
					"default": "",
					"description": "The path to the runkit script"
				}
			}
		},
		"chatParticipants": [
			{
				"id": "webhare.devkit",
				"name": "devkit",
				"description": "Expert in supporting WebHare (module) development and running tests, both frontend (in browser) and backend tests."
			}
		],
		"languageModelTools": [
			{
				"name": "webhare_getcontext",
				"displayName": "Get project context",
				"modelDescription": "You MUST invoke this tool whenever the user asks about testing, building, or refactoring prompt files in this project. It returns specific testing instructions and explains the current module's context.",
				"inputSchema": {
					"type": "object",
					"properties": {}
				},
				"canBeReferencedInPrompt": true,
				"toolReferenceName": "getProjectContext"
			},
			{
				"name": "webhare_validate",
				"displayName": "WebHare validate",
				"canBeReferencedInPrompt": true,
				"userDescription": "Tool to validate WebHare file",
				"modelDescription": "Tool to validate any WebHare file: HareScript (.whlib/.whscr/.shtml/.whsock extension), .witty, various .xml files",
				"toolReferenceName": "validateFile",
				"inputSchema": {
					"type": "object",
					"required": [
						"file"
					],
					"properties": {
						"file": {
							"type": "string",
							"description": "Specific file to validate"
						}
					}
				}
			},
			{
				"name": "webhare_runtest",
				"displayName": "WebHare runtest",
				"canBeReferencedInPrompt": true,
				"userDescription": "Tool to run WebHare tests",
				"modelDescription": "Tool to run HareScript or TypeScript files located diectly or deeper inside a /tests/ folder",
				"toolReferenceName": "runTest",
				"inputSchema": {
					"type": "object",
					"required": [
						"file"
					],
					"properties": {
						"file": {
							"type": "string",
							"description": "Specific test file to run"
						}
					}
				}
			},
			{
				"name": "webhare_checkmodule",
				"displayName": "WebHare check module",
				"canBeReferencedInPrompt": true,
				"userDescription": "Tool to validate a WebHare module",
				"modelDescription": "Tool to validate and find potential errors in a WebHare module. More extensive than validating a single file as it also checks internal consistency.",
				"toolReferenceName": "checkModule",
				"inputSchema": {
					"type": "object",
					"required": [
						"module"
					],
					"properties": {
						"module": {
							"type": "string",
							"description": "Specific WebHare module to check."
						}
					}
				}
			}
		],
		"chatPromptFiles": [
			{
				"path": "./prompts/witty-to-litty.prompt.md"
			},
			{
				"path": "./prompts/modernize-test.prompt.md"
			}
		],
		"chatSkills": [
			{
				"path": "./skills/typescript-development/SKILL.md"
			},
			{
				"path": "./skills/running-tests/SKILL.md"
			},
			{
				"path": "./skills/build-modernize-tests/SKILL.md"
			}
		],
		"mcpServerDefinitionProviders": [
			{
				"id": "webhare-devkit-mcp",
				"label": "WebHare Devkit MCP Server"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "../../whtree/node_modules/.bin/tsc -b",
		"watch": "../../whtree/node_modules/.bin/tsc -b -w",
		"test": "sh ./scripts/run-extension-tests.sh"
	},
	"dependencies": {
		"@webhare/lsp-types": "file:../../whtree/jssdk/lsp-types",
		"vscode-languageclient": "^9.0.1",
		"vscode-languageserver-types": "^3.17.5"
	},
	"devDependencies": {
		"@types/node": "^20.11.7",
		"@types/vscode": "^1.108.1",
		"@vscode/vsce": "^3.7.1"
	}
}
